NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:3000

DB_TARGET=local
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=dira news
LOCAL_DB_USER=postgres
LOCAL_DB_PASSWORD=replace-with-local-password
LOCAL_DB_SCHEMA=public
DATABASE_URL=postgresql://dira:dira@localhost:5432/dira_news?schema=public
DATABASE_URL_NEON=
REDIS_URL=redis://localhost:6379

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-admin-password
ADMIN_NAME=Admin

JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=dira-news-media
S3_ACCESS_KEY=dira
S3_SECRET_KEY=dira-password
S3_FORCE_PATH_STYLE=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHANNEL_ID=
